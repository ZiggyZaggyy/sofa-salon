# =============================================================================
# 复制此文件为 .env.local 然后填入真实值。.env.local 已被 .gitignore 忽略，不会提交。
# Copy this file to .env.local and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase（必填）
# 在 Supabase Dashboard → 项目 → Settings → API 里可以看到
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# -----------------------------------------------------------------------------
# Supabase Service Role（可选）
# 仅用于：取消预约后自动把 waitlist 第一个人升级、发 promotion 邮件时需要查用户 email
# 在 Settings → API → service_role（保密，不要暴露到前端）
# -----------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# -----------------------------------------------------------------------------
# Resend 发邮件（可选）
# 用于：预约确认邮件、waitlist 升级通知。不填则不发邮件，预约/升级功能仍可用
# https://resend.com 注册后拿 API Key
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=onboarding@resend.dev

# -----------------------------------------------------------------------------
# 应用名称（可选）
# 不填则默认 "Sofa Salon" / "Your host's living room"
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_NAME=Sofa Salon
# NEXT_PUBLIC_APP_TAGLINE=Ziggy's living room

# -----------------------------------------------------------------------------
# 生产环境完整地址（可选）
# 用于 OAuth 回调等重定向。Vercel 部署时一般用 x-forwarded-host 即可；
# 若登录后仍被导向 localhost，可在此填写生产地址，如 https://ziggygraph.vercel.app
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=https://ziggygraph.vercel.app
