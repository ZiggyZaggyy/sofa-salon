# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is in .gitignore and will not be committed.
# =============================================================================

# === Required (app will not work without these) ===
# Supabase: Dashboard → Project Settings → API
# - Project URL → NEXT_PUBLIC_SUPABASE_URL
# - Project API keys → anon public → NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# === Optional (server / backend) ===
# Supabase Service Role key (Dashboard → Settings → API → service_role).
# Needed for: waitlist promotion, sending emails, admin guest attendance (reservations.attended).
# Without this OR supabase-sql/30-reservations-admin-update-rls.sql, admin attendance
# PATCH returns 503 (reservations not updated); blood bar and dropdown stay in sync.
# Keep secret; never expose to the client.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# IANA timezone for screening times in emails (server runs in UTC). Default: America/New_York
# VENUE_TIMEZONE=America/New_York

# Resend (https://resend.com): API key for sending emails (confirmation, waitlist promotion, reminders).
# If unset, reservation and waitlist still work; no emails are sent.
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM: use an address on a domain you verified in Resend Domains (required to email arbitrary recipients).
# EMAIL_FROM=Your App <noreply@yourdomain.com>
# With onboarding@resend.dev (default), Resend only delivers to your Resend signup email until you verify a domain.
# Inbox for /contact “message the host” form (required for that feature to send)
# HOST_CONTACT_EMAIL=your-inbox@example.com

# Cron routes (e.g. event reminders, post-event rating): secret so only your cron job can call them.
# CRON_SECRET=your-secret-string

# === Optional (public / display) ===
# App name and tagline shown in the UI. Defaults: "Sofa Salon" / "Your host's living room"
# NEXT_PUBLIC_APP_NAME=Sofa Salon
# NEXT_PUBLIC_APP_TAGLINE="Ziggy's living room"
#
# Locale-specific "Past Screenings" destinations in the navigation.
# NEXT_PUBLIC_PAST_SCREENINGS_URL_EN=https://letterboxd.com/your-account/list/your-screenings/
# NEXT_PUBLIC_PAST_SCREENINGS_URL_ZH=https://example.com/your-chinese-archive
#
# Public attribution and host identity used in navigation, help text, and receipts.
# NEXT_PUBLIC_DEVELOPER_NAME=Your Name
# NEXT_PUBLIC_DEVELOPER_URL=https://github.com/your-account
# NEXT_PUBLIC_HOST_NAME=Host Name
# NEXT_PUBLIC_VENUE_ADDRESS="City, State"
# NEXT_PUBLIC_RECEIPT_SUBTITLE="SCREENING ROOM"
#
# Mascot story links used by the FAQ and cancellation easter egg.
# Set either value to an empty string to disable that link/embed.
# NEXT_PUBLIC_MASCOT_STORY_URL=https://youtube.com/shorts/your-video
# NEXT_PUBLIC_MASCOT_STORY_EMBED_URL=https://www.youtube.com/embed/your-video
#
# Leaderboard: display name(s) for salon host (rank #0, hidden from table). Co-admins still rank normally.
# "Of X guests" counts only guests with ≥1 attended screening, not every registered profile.
# LEADERBOARD_HOST_DISPLAY_NAMES=Ziggy
#
# OMDb (scripts only — one KEY=value per line; do not append on the tagline line):
#   node scripts/fetch-historical-durations-omdb.mjs
# OMDB_API_KEY=your-key-here
# https://www.omdbapi.com/apikey.aspx

# Fallback origin when the request has no Host (rare). Auth callbacks prefer the host the user actually opened (custom domain vs vercel.app).
# Optional: set to your primary production URL (e.g. https://ziggygraph.app).
# NEXT_PUBLIC_APP_URL=https://ziggygraph.vercel.app

# Public links in emails and WeChat-style announcements (group announcement API).
# Set this in production. When unset, it falls back to NEXT_PUBLIC_APP_URL, then http://localhost:3000.
# NEXT_PUBLIC_CUSTOMER_SITE_URL=https://your-domain.example
